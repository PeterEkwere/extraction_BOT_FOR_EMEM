{
  "name": "form-automation-tool",
  "version": "1.0.0",
  "description": "Automated web form submission tool with Electron",
  "main": "db-worker.js",
  "homepage": "./",
  "bin": {
    "form-automate": "./cli.js"
  },
  "scripts": {
    "start": "electron .",
    "dev": "cross-env NODE_ENV=development electron .",
    "build": "electron-builder",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "postinstall": "electron-builder install-app-deps",
    "cli": "node cli.js",
    "test": "jest",
    "format": "prettier --write \"**/*.{js,jsx,json,md}\"",
    "electron-rebuild": "electron-rebuild -f -w .",
    "start:worker": "electron db-worker.js",
    "audit": "electron audit.js"
  },
  "dependencies": {
    "@electron/remote": "^2.1.0",
    "axios": "^1.6.2",
    "chalk": "^4.1.2",
    "commander": "^14.0.0",
    "csv-parse": "^5.5.0",
    "date-fns": "^4.1.0",
    "electron": "^28.0.0",
    "electron-store": "^8.1.0",
    "https-proxy-agent": "^7.0.2",
    "node-fetch": "^2.6.7",
    "p-queue": "^8.0.1",
    "p-retry": "^5.1.1",
    "puppeteer": "^21.0.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "random-useragent": "^0.5.0",
    "yargs": "^17.7.1"
  },
  "devDependencies": {
    "@types/node": "^20.8.0",
    "@types/puppeteer": "^5.4.7",
    "cross-env": "^7.0.3",
    "electron": "^28.0.0",
    "electron-builder": "^26.0.12",
    "electron-rebuild": "^3.2.9",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.0.3"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ]
  }
}
